# Since the ".env" file is gitignored, you can use the ".env.example" file to
# build a new ".env" file when you clone the repo. Keep this file up-to-date
# when you add new variables to `.env`.

# This file will be committed to version control, so make sure not to have any
# secrets in it. If you are cloning this repo, create a copy of this file named
# ".env" and populate it with your secrets.

# When adding additional environment variables, the schema in "/src/env.js"
# should be updated accordingly. Run `pnpm check:env` to verify sync.

# Prisma
# https://www.prisma.io/docs/reference/database-reference/connection-urls#env
DATABASE_URL="postgresql://postgres:password@localhost:5432/thomson-print-portal"

# Next Auth
# You can generate a new secret on the command line with:
# openssl rand -base64 32
# https://next-auth.js.org/configuration/options#secret
# Required in production; optional in development
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"

# Next Auth Google Provider
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# App URLs
PUBLIC_BASE_URL="http://localhost:3000"
NEXT_PUBLIC_BASE_URL="http://localhost:3000"
WEBSITE_URL="http://localhost:3000"

# OpenAI
OPENAI_API_KEY=""
NEXT_PUBLIC_OPENAI_API_KEY=""

# QuickBooks
QUICKBOOKS_CLIENT_ID=""
QUICKBOOKS_CLIENT_SECRET=""
QUICKBOOKS_ENVIRONMENT="sandbox"
NEXT_PUBLIC_QUICKBOOKS_CLIENT_ID=""
NEXT_PUBLIC_QUICKBOOKS_CLIENT_SECRET=""
NEXT_PUBLIC_QUICKBOOKS_ENVIRONMENT="sandbox"

# Pusher
NEXT_PUBLIC_PUSHER_KEY=""
NEXT_PUBLIC_PUSHER_CLUSTER=""

# SendGrid (SMTP)
SENDGRID_ADMIN_EMAIL=""
SENDGRID_SMTP_USER="apikey"
SENDGRID_SMTP_PASSWORD=""
SENDGRID_SMTP_HOST="smtp.sendgrid.net"
SENDGRID_SMTP_PORT="587"
SENDGRID_EMAIL_FROM=""
SENDGRID_MAGIC_LINK_TEMPLATE_ID=""
SENDGRID_ORDER_STATUS_TEMPLATE_ID=""
SENDGRID_ORDER_TEMPLATE_ID=""

# Honeybadger
HONEYBADGER_API_KEY=""
# Defaults to "development" if not set
HONEYBADGER_ENV="development"
NEXT_PUBLIC_HONEYBADGER_API_KEY=""
